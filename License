                    offer2Meta: "Дата вступления в силу: 22 октября 2025 • PAT-STUDIO"
                },
                en: {
                    pageTitle: "Legal Documents | PAT-STUDIO",
                    btnHome: "Main Page",
                    offer1Title: "PUBLIC OFFER (1)",
                    offer1Meta: "License agreement • Owner • October 22, 2025 at 21:55",
                    offer2Title: "PUBLIC OFFER (2)",
                    offer2Meta: "Effective Date: October 22, 2025 • PAT-STUDIO"
                },
                zh: {
                    pageTitle: "法律文件 | PAT-STUDIO",
                    btnHome: "回到首页",
                    offer1Title: "公开发售 (1)",
                    offer1Meta: "许可协议 • 所有者 • 2025年10月22日 21:55",
                    offer2Title: "公开发售 (2)",
                    offer2Meta: "生效日期：2025年10月22日 • PAT-STUDIO"
                },
                it: {
                    pageTitle: "Documenti Legali | PAT-STUDIO",
                    btnHome: "Home Page",
                    offer1Title: "OFFERTA PUBBLICA (1)",
                    offer1Meta: "Contratto di licenza • Proprietario • 22 ottobre 2025 alle 21:55",
                    offer2Title: "OFFERTA PUBBLICA (2)",
                    offer2Meta: "Data di entrata in vigore: 22 ottobre 2025 • PAT-STUDIO"
                },
                ar: {
                    pageTitle: "المستندات القانونية | PAT-STUDIO",
                    btnHome: "الصفحة الرئيسية",
                    offer1Title: "العرض العام (1)",
                    offer1Meta: "اتفاقية الترخيص • المالك • 22 أكتوبر 2025 الساعة 21:55",
                    offer2Title: "العرض العام (2)",
                    offer2Meta: "تاريخ النفاذ: 22 أكتوبر 2025 • PAT-STUDIO"
                }
            },

            init() {
                this.setupTheme();
                this.setupLanguage();
            },

            setupTheme() {
                const savedTheme = localStorage.getItem('pat_theme') || localStorage.getItem('theme') || 'light';
                document.documentElement.setAttribute('data-theme', savedTheme);
                if (savedTheme === 'dark') {
                    document.body.classList.add('dark-theme', 'dark');
                } else {
                    document.body.classList.remove('dark-theme', 'dark');
                }
            },

            setupLanguage() {
                let savedLang = localStorage.getItem('pat_lang') || localStorage.getItem('language') || 'ru';
                if (!this.translations[savedLang]) savedLang = 'en';

                document.documentElement.lang = savedLang;
                document.title = this.translations[savedLang].pageTitle;

                if (savedLang === 'ar') {
                    document.body.classList.add('rtl');
                } else {
                    document.body.classList.remove('rtl');
                }

                // Короткие переводы через data-key
                document.querySelectorAll('[data-key]').forEach(element => {
                    const key = element.getAttribute('data-key');
                    if (this.translations[savedLang] && this.translations[savedLang][key]) {
                        element.textContent = this.translations[savedLang][key];
                    }
                });

                // Переключение отображения больших текстовых блоков документов
                const supportedDocLangs = ['ru', 'en'];
                const targetDocLang = supportedDocLangs.includes(savedLang) ? savedLang : 'en'; // Если zh/it/ar нет, показываем en

                document.querySelectorAll('[data-lang]').forEach(element => {
                    if (element.getAttribute('data-lang') === targetDocLang) {
                        element.style.display = 'block';
                    } else {
                        element.style.display = 'none';
                    }
                });
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            LegalEngine.init();
        });
    </script>
